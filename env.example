# --- Required in production ---
APT_SECRET_KEY=change-me-to-a-long-random-string     # python -c "import secrets; print(secrets.token_urlsafe(32))"
APT_BASE_URL=http://localhost:8000                   # e.g. https://apt.example.com
APT_DOMAIN=:80                                       # e.g. apt.example.com (enables automatic HTTPS)

# --- Google OAuth (console.cloud.google.com; redirect URI = $APT_BASE_URL/api/auth/callback) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin ---
APT_ADMIN_EMAILS=you@example.com

# --- Telegram (optional; enables the bot channel + `--profile bot`) ---
TELEGRAM_BOT_TOKEN=
APT_BOT_USERNAME=

# --- Email via Brevo (optional) ---
BREVO_API_KEY=
APT_EMAIL_FROM=

# --- Paths / tuning (defaults are fine) ---
APT_DB_PATH=data/apt.db
APT_SCRAPE_INTERVAL_SECONDS=900
# Set APT_SITE_URL to the SAME value as APT_BASE_URL (env_file does not expand ${...})
APT_SITE_URL=http://localhost:8000
# APT_PORT=8000                                       # must match deploy/Caddyfile's reverse_proxy target
# APT_FB_SESSION_FILE=data/fb-session.json            # future facebook source
